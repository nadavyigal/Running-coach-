{
  "extends": "./tsconfig.core.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false
  },
  "exclude": [
    "node_modules",
    ".next",
    "e2e",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    "**/tests/**",
    "playwright-report",
    "coverage",
    "reports",
    "app/admin/**",
    "app/api/**",
    "app/(experimental)/**",
    "app/(share)/**",
    "app/devices/**",
    "app/page-backup.tsx",
    "components/challenge-picker.tsx",
    "components/find-my-route-modal.tsx",
    "components/heart-rate-zones-config.tsx",
    "components/heart-rate-zones-display.tsx",
    "components/plan-customization-dashboard.tsx",
    "components/race-goal-modal.tsx",
    "components/race-goals-screen.tsx",
    "components/running-dynamics-visualization.tsx",
    "experimental/**",
    "lib/abTestFramework.ts",
    "lib/chatDriver.ts",
    "lib/compression.ts",
    "lib/dbTransactions.ts",
    "lib/email/sequences.ts",
    "lib/error-monitoring.ts",
    "lib/error-recovery.ts",
    "lib/errorHandler.middleware.ts",
    "lib/onboardingSessionManager.ts",
    "lib/performance.config.ts",
    "lib/performance.monitoring.ts",
    "lib/security.middleware.ts",
    "lib/security.monitoring.ts",
    "lib/server/activityImagePreprocess.ts",
    "lib/test-utils.ts",
    "playground/**",
    "scripts/**"
  ]
}

