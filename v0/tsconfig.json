{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES2020",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/components/ui/*": [
        "./components/ui/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "e2e/**",
    "__tests__/**",
    "app/api/**",
    "app/admin/**",
    "app/(experimental)/**",
    "app/(share)/**",
    "app/devices/**",
    "app/page-backup.tsx",
    "components/challenge-picker.tsx",
    "components/find-my-route-modal.tsx",
    "components/heart-rate-zones-config.tsx",
    "components/heart-rate-zones-display.tsx",
    "components/plan-customization-dashboard.tsx",
    "components/race-goal-modal.tsx",
    "components/race-goals-screen.tsx",
    "components/running-dynamics-visualization.tsx",
    "lib/abTestFramework.ts",
    "lib/chatDriver.ts",
    "lib/compression.ts",
    "lib/dbTransactions.ts",
    "lib/email/sequences.ts",
    "lib/error-monitoring.ts",
    "lib/error-recovery.ts",
    "lib/errorHandler.middleware.ts",
    "lib/onboardingSessionManager.ts",
    "lib/performance.config.ts",
    "lib/performance.monitoring.ts",
    "lib/security.middleware.ts",
    "lib/security.monitoring.ts",
    "lib/server/activityImagePreprocess.ts",
    "lib/test-utils.ts",
    "vitest.setup.ts",
    "scripts/**"
  ]
}
